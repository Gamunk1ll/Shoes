<Window x:Class="Shoes.AddEditOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes"
        mc:Ignorable="d"
        Title="Заказ" Height="450" Width="800">
    <Grid Height="434" VerticalAlignment="Top">
        <Grid Margin="0,0,0,174">
            <Border BorderBrush="Black" BorderThickness="2" Margin="10,0,147,0">
                <StackPanel>
                    <TextBox x:Name="ArticleTextBox" TextWrapping="Wrap" Text="" Width="400" FontWeight="Bold" FontSize="16"/>
                    <ComboBox x:Name="OrderStatusComboBox" Margin="0,5,0,5"/>
                    <ComboBox x:Name="PickPointComboBox" Margin="0,5,0,5"/>
                    <DatePicker x:Name="OrderDatePicker" Margin="0,5,0,5"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="Black" BorderThickness="2" Margin="658,0,10,0">
                <DatePicker x:Name="DeliveryDatePicker" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
        <Button x:Name="SaveButton" Content="Сохранить" HorizontalAlignment="Left" Margin="34,282,0,0" VerticalAlignment="Top" Height="43" Width="144" Click="SaveButton_Click"/>
        <Button x:Name="BackButton" Content="Назад" HorizontalAlignment="Left" Margin="616,282,0,0" VerticalAlignment="Top" Height="42" Width="144" Click="BackButton_Click"/>
    </Grid>
</Window>