<UserControl x:Class="Shoes.OrderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Shoes"
             mc:Ignorable="d" 
             FontFamily="Times New Roman" FontSize="14" Background="#7FFF00" d:Width="800" Height="125">
    <Border BorderThickness="2">
        <Grid>
            <Border BorderBrush="Black" BorderThickness="2" Margin="10,0,181,0">
                <StackPanel>
                    <TextBlock x:Name="ArticleTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400" FontWeight="Bold" FontSize="16"/>
                    <TextBlock x:Name="OrderStatusTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400"/>
                    <TextBlock x:Name="PickPointAddressTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400"/>
                    <TextBlock x:Name="OrderDateTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="Black" BorderThickness="2" Margin="620,0,0,0">
                <TextBlock x:Name="DeliveryDateTextBlock" TextWrapping="Wrap" Text="TextBlock" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
