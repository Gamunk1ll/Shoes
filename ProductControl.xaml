<UserControl x:Class="Shoes.ProductControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Shoes"
             mc:Ignorable="d" FontFamily="Times New Roman" FontSize="14" Background="#7FFF00" d:Width="800" Height="125">
    <Border BorderThickness="2">
        <Grid>
            <Border Margin="10,10,596,0">
                <Image x:Name="PhotoProductImage" Source="/picture.png"/>
            </Border>
            <Border BorderBrush="Black" BorderThickness="2" Margin="193,0,181,0">
                <StackPanel>
                    <TextBlock x:Name="TypeNameTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400" FontWeight="Bold" FontSize="16"/>
                    <TextBlock x:Name="DescriptionTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400"/>
                    <TextBlock x:Name="ManufacturerNametextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400"/>
                    <TextBlock x:Name="SupplierNameTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400"/>
                    <TextBlock x:Name="PriceTextBlock" TextWrapping="Wrap" Text="" Width="400">
                        <Run x:Name="OldPrice"/>
                        <Run x:Name="NewPrice"/>
                    </TextBlock>
                    <TextBlock x:Name="UnitMetricTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400"/>
                    <TextBlock x:Name="AmountTextBlock" TextWrapping="Wrap" Text="TextBlock" Width="400"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="Black" BorderThickness="2" Margin="620,0,0,0">
                <TextBlock x:Name="DiscountTextBlock" TextWrapping="Wrap" Text="TextBlock" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
